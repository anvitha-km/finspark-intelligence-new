# FinSpark Intelligence — Server Configuration
# Copy this file to .env and fill in your values

# Server
PORT=4000
NODE_ENV=development

# CORS — comma separated list of allowed dashboard origins
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# Data retention — how many days to keep events (default 90)
RETENTION_DAYS=90

# Rate limiting
EVENT_RATE_LIMIT=60
ANALYTICS_RATE_LIMIT=300
